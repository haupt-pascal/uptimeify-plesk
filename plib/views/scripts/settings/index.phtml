<?php
/** @var Zend_View $this */
$connected = (bool) ($this->connected ?? false);
$orgName   = (string) ($this->orgName ?? '');
?>
<?php if (!$connected): ?>
    <h3><?= $this->escape($this->lmsg('settings.step1Title')) ?></h3>
    <p><?= $this->escape($this->lmsg('settings.step1Intro')) ?></p>
    <p>
        <a href="https://uptimeify.io" target="_blank" rel="noopener">
            <?= $this->escape($this->lmsg('settings.getToken')) ?>
        </a>
    </p>
<?php else: ?>
    <h3><?= $this->escape($this->lmsg('settings.step2Title')) ?></h3>
    <p><?= $this->escape($this->lmsg('settings.step2Intro', ['org' => $orgName])) ?></p>
    <p>
        <a class="btn" href="<?= $this->escape(pm_Context::getActionUrl('index', 'index')) ?>">
            <?= $this->escape($this->lmsg('settings.goToDashboard')) ?>
        </a>
    </p>
<?php endif; ?>

<?= $this->form ?>
