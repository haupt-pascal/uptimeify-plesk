<?php
/** @var Zend_View $this */
$rows           = $this->rows ?? [];
$customers      = $this->customers ?? [];
$packages       = $this->packages ?? [];
$defaultPackage = (string) ($this->defaultPackage ?? '');
$loadError      = $this->loadError ?? null;

$statusLabels = [
    'active'      => $this->lmsg('dashboard.statusActive'),
    'inactive'    => $this->lmsg('dashboard.statusInactive'),
    'paused'      => $this->lmsg('dashboard.statusInactive'),
    'maintenance' => $this->lmsg('dashboard.statusMaintenance'),
];
?>
<div class="uptimeify-dashboard">
    <p>
        <strong><?= $this->escape($this->organizationName ?: '') ?></strong>
        &nbsp;
        <button type="button" class="btn" id="uptimeify-sync-selected"
                data-url="<?= $this->escape(pm_Context::getActionUrl('index', 'sync-selected')) ?>">
            <?= $this->escape($this->lmsg('dashboard.syncSelected')) ?>
        </button>
        <button type="button" class="btn" id="uptimeify-sync-all"
                data-url="<?= $this->escape(pm_Context::getActionUrl('index', 'sync')) ?>">
            <?= $this->escape($this->lmsg('dashboard.syncAll')) ?>
        </button>
        <a class="btn" href="<?= $this->escape(pm_Context::getActionUrl('settings', 'index')) ?>">
            <?= $this->escape($this->lmsg('dashboard.openSettings')) ?>
        </a>
        <span class="hint"><?= $this->escape($this->lmsg('dashboard.syncAllHint')) ?></span>
    </p>

    <?php if ($loadError): ?>
        <div class="msg-box msg-error"><div class="msg-content"><?= $this->escape($loadError) ?></div></div>
    <?php endif; ?>

    <p>
        <input type="text" id="uptimeify-filter" size="40"
               placeholder="<?= $this->escape($this->lmsg('dashboard.filter')) ?>">
    </p>

    <table class="list" width="100%" id="uptimeify-table">
        <thead>
        <tr>
            <th><input type="checkbox" id="uptimeify-select-all" title="<?= $this->escape($this->lmsg('dashboard.selectAll')) ?>"></th>
            <th><?= $this->escape($this->lmsg('dashboard.colDomain')) ?></th>
            <th><?= $this->escape($this->lmsg('dashboard.colOwner')) ?></th>
            <th><?= $this->escape($this->lmsg('dashboard.colCustomer')) ?></th>
            <th><?= $this->escape($this->lmsg('dashboard.colStatus')) ?></th>
            <th><?= $this->escape($this->lmsg('dashboard.colMonitoring')) ?></th>
        </tr>
        </thead>
        <tbody>
        <?php foreach ($rows as $row): ?>
            <tr class="uptimeify-row" data-domain="<?= $this->escape($row['domain']) ?>">
                <td>
                    <?php if (!$row['monitored']): ?>
                        <input type="checkbox" class="uptimeify-select" data-domain="<?= $this->escape($row['domain']) ?>">
                    <?php endif; ?>
                </td>
                <td><?= $this->escape($row['domain']) ?></td>
                <td><?= $this->escape($row['ownerName'] ?: '—') ?></td>
                <td>
                    <?php if (!empty($row['customerName'])): ?>
                        <?= $this->escape($row['customerName']) ?>
                    <?php elseif (!$row['monitored']): ?>
                        <span class="hint">&rarr; <?= $this->escape($row['ownerName'] ?: $row['domain']) ?></span>
                    <?php else: ?>
                        —
                    <?php endif; ?>
                </td>
                <td>
                    <?php $st = (string) ($row['status'] ?? ''); ?>
                    <?= $st !== '' ? $this->escape($statusLabels[$st] ?? $st) : '—' ?>
                </td>
                <td>
                    <?php if ($row['monitored']): ?>
                        <span class="uptimeify-active">
                            <label>
                                <input type="checkbox" checked
                                       class="uptimeify-monitor-toggle"
                                       data-domain="<?= $this->escape($row['domain']) ?>"
                                       data-website="<?= $this->escape($row['websitePublicId'] ?? '') ?>">
                                <?= $this->escape($this->lmsg('dashboard.active')) ?>
                            </label>
                        </span>
                        <span class="uptimeify-confirm" style="display:none">
                            <?= $this->escape($this->lmsg('dashboard.removeConfirm')) ?>
                            <button type="button" class="btn uptimeify-confirm-yes"
                                    data-domain="<?= $this->escape($row['domain']) ?>"
                                    data-website="<?= $this->escape($row['websitePublicId'] ?? '') ?>">
                                <?= $this->escape($this->lmsg('dashboard.remove')) ?>
                            </button>
                            <button type="button" class="btn uptimeify-confirm-no">
                                <?= $this->escape($this->lmsg('dashboard.cancel')) ?>
                            </button>
                        </span>
                    <?php else: ?>
                        <span class="uptimeify-enable">
                            <select class="uptimeify-customer" title="<?= $this->escape($this->lmsg('dashboard.colCustomer')) ?>">
                                <option value="auto">
                                    <?= $this->escape($this->lmsg('dashboard.autoCustomer', ['owner' => $row['ownerName'] ?: $row['domain']])) ?>
                                </option>
                                <?php foreach ($customers as $c): ?>
                                    <option value="<?= $this->escape($c['publicId']) ?>"
                                        <?= (($row['customerPublicId'] ?? null) === $c['publicId']) ? 'selected' : '' ?>>
                                        <?= $this->escape($c['name']) ?>
                                    </option>
                                <?php endforeach; ?>
                            </select>
                            <select class="uptimeify-package" title="<?= $this->escape($this->lmsg('dashboard.choosePackage')) ?>">
                                <option value=""><?= $this->escape($this->lmsg('dashboard.choosePackage')) ?></option>
                                <?php foreach ($packages as $p): ?>
                                    <?php $pt = (string) ($p['packageType'] ?? ''); ?>
                                    <option value="<?= $this->escape($pt) ?>"
                                        <?= ($pt !== '' && $pt === $defaultPackage) ? 'selected' : '' ?>>
                                        <?= $this->escape($p['displayName'] ?? $p['packageType'] ?? '') ?>
                                    </option>
                                <?php endforeach; ?>
                            </select>
                            <button type="button" class="btn uptimeify-enable-btn"
                                    data-domain="<?= $this->escape($row['domain']) ?>">
                                <?= $this->escape($this->lmsg('dashboard.enable')) ?>
                            </button>
                        </span>
                    <?php endif; ?>
                </td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>

    <?php if (!$rows && !$loadError): ?>
        <p><?= $this->escape($this->lmsg('dashboard.noDomains')) ?></p>
    <?php endif; ?>
</div>

<script>
    window.UPTIMEIFY = {
        enableUrl: <?= json_encode(pm_Context::getActionUrl('index', 'enable')) ?>,
        disableUrl: <?= json_encode(pm_Context::getActionUrl('index', 'disable')) ?>,
        syncSelectedUrl: <?= json_encode(pm_Context::getActionUrl('index', 'sync-selected')) ?>,
        i18n: {
            selectFirst: <?= json_encode($this->lmsg('dashboard.selectFirst')) ?>
        }
    };
</script>
